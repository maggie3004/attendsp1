# ============================================
# AttendSP - .gitignore
# ============================================

# ---- Dependencies ----
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ---- Next.js Build ----
/.next/
/out/
/build

# ---- Production ----
dist/

# ---- Environment Variables (NEVER commit these) ----
.env
.env.local
.env.development
.env.test
.env.production
.env.staging
.env*.local
!.env.example
!.env.local.example

# ---- Prisma ----
prisma/*.db
prisma/*.db-journal

# ---- Testing ----
/coverage
/test-results/
/playwright-report/

# ---- Misc ----
.DS_Store
*.pem
Thumbs.db
*.log

# ---- Debug Logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---- Editor ----
.vscode/settings.json
.idea/
*.swp
*.swo

# ---- Vercel ----
.vercel

# ---- TypeScript ----
*.tsbuildinfo
next-env.d.ts

# ---- OS ----
Desktop.ini
ehthumbs.db

# ---- Cloudinary (never commit upload presets with secrets) ----
cloudinary.json
