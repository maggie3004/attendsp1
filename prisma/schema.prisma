// ============================================================
// AttendSP Prisma Schema
// Provider: Neon PostgreSQL
// ORM: Prisma v6
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

// ============================================================
// Enums
// ============================================================

enum Role {
  ADMIN
  EMPLOYEE
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  TERMINATED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
}

enum LeaveType {
  PAID
  UNPAID
  ADVANCE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum SiteStatus {
  ACTIVE
  INACTIVE
  COMPLETED
}

enum NotificationType {
  ATTENDANCE
  LEAVE
  SYSTEM
  ALERT
}

// ============================================================
// Models
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          Role      @default(EMPLOYEE)
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  employee      Employee?
  notifications Notification[]
  approvedLeaves Leave[] @relation("ApprovedBy")

  @@map("users")
}

model Employee {
  id             String         @id @default(cuid())
  userId         String         @unique
  employeeCode   String         @unique
  designation    String
  department     String
  phone          String?
  address        String?
  faceImage      String?
  joinDate       DateTime       @default(now())
  status         EmployeeStatus @default(ACTIVE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  siteEmployees  SiteEmployee[]
  attendances    Attendance[]
  leaves         Leave[]

  @@map("employees")
}

model Site {
  id            String       @id @default(cuid())
  name          String
  location      String
  address       String
  latitude      Float?
  longitude     Float?
  radius        Int          @default(200) // meters
  status        SiteStatus   @default(ACTIVE)
  image         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  siteEmployees SiteEmployee[]
  attendances   Attendance[]

  @@map("sites")
}

model SiteEmployee {
  id         String   @id @default(cuid())
  siteId     String
  employeeId String
  assignedAt DateTime @default(now())
  isActive   Boolean  @default(true)

  site       Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([siteId, employeeId])
  @@map("site_employees")
}

model Attendance {
  id            String           @id @default(cuid())
  employeeId    String
  siteId        String?
  date          DateTime         @db.Date
  checkInTime   DateTime?
  checkOutTime  DateTime?
  checkInImage  String?
  checkInLat    Float?
  checkInLng    Float?
  checkOutImage String?
  checkOutLat   Float?
  checkOutLng   Float?
  status        AttendanceStatus @default(PRESENT)
  notes         String?
  isManual      Boolean          @default(false)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  employee      Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  site          Site?            @relation(fields: [siteId], references: [id], onDelete: SetNull)

  @@unique([employeeId, date])
  @@map("attendances")
}

model Leave {
  id           String      @id @default(cuid())
  employeeId   String
  leaveType    LeaveType   @default(PAID)
  startDate    DateTime    @db.Date
  endDate      DateTime    @db.Date
  totalDays    Int         @default(1)
  reason       String
  status       LeaveStatus @default(PENDING)
  approvedById String?
  approvedAt   DateTime?
  rejectionNote String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  employee     Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  approvedBy   User?       @relation("ApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  @@map("leaves")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(SYSTEM)
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model SystemSettings {
  id                String   @id @default("global")

  // Company
  companyName       String   @default("AttendSP Construction")
  workStartTime     String   @default("09:00") // HH:mm
  workEndTime       String   @default("18:00") // HH:mm
  lateThresholdMins Int      @default(30)

  // Attendance
  geofenceEnabled   Boolean  @default(true)
  faceCaptureEnabled Boolean @default(true)
  autoMarkAbsent    Boolean  @default(false)

  // Notifications
  leaveAlerts       Boolean  @default(true)
  lateAlerts        Boolean  @default(true)

  updatedAt         DateTime @updatedAt

  @@map("system_settings")
}
